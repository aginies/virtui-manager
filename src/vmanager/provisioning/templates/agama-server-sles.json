{
  "hostname": {
    "static": "{hostname}"
  },
  "localization": {
    "language": "{language}",
    "keyboard": "{keyboard}",
    "timezone": "{timezone}"
  },
  "root": {
    "hashedPassword": true,
    "password": "{root_password}"
  },
  "user": {
    "hashedPassword": true,
    "fullName": "{username}",
    "userName": "{username}",
    "password": "{user_password}"
  },
  "product": {
    "id": "SLES",
    "registrationCode": "{scc_reg_code}",
    "registrationEmail": "{scc_email}"
  },
  "software": {
    "patterns": {
      "add": [ "enhanced_base" ]
    },
    "packages": [
      "qemu-guest-agent",
      "spice-vdagent",
      "openssh",
      "samba",
      "nfs-client",
      "firewalld",
      "rsync",
      "vim",
      "curl",
      "wget"
    ]
  },
  "bootloader": {
    "timeout": 5,
    "extraKernelParams": "quiet splash=silent showopts"
  },
  "network": {
    "connections": [
      {
        "id": "default",
        "method4": "auto"
      }
    ]
  },
  "storage": {
    "drives": [
      {
        "search": "/dev/vda",
        "partitions": [
          { "generate": "default" }
        ]
      }
    ]
  }
}
