{
  "hostname": {
    "static": "{hostname}",
    "transient": "{hostname}"
  },
  "localization": {
    "language": "{language}",
    "keyboard": "{keyboard}",
    "timezone": "{timezone}"
  },
   "root": {
    "hashedPassword": false,
    "password": "{root_password}"
  },
  "user": {
    "hashedPassword": false,
    "fullName": "{username}",
    "userName": "{username}",
    "password": "{user_password}"
  },
  "software": {
    "patterns": [
      "base",
      "enhanced_base",
      "yast2_basis",
      "gnome",
      "gnome_basis"
    ],
    "packages": [
      "qemu-guest-agent",
      "spice-vdagent",
      "openssh",
      "vim",
      "curl",
      "wget",
      "tree",
      "htop",
      "MozillaFirefox"
    ]
  },
  "bootloader": {
    "timeout": 8,
    "extraKernelParams": "quiet splash=silent showopts"
  },
  "network": {
    "connections": [
      {
        "id": "default",
        "method4": "auto"
      }
    ]
  },
  "storage": {
    "boot": {
      "configure": true,
      "device": "vda"
    },
    "drives": [
      {
        "partitions": [
          {
            "filesystem": {
              "type": "vfat",
              "path": "/boot/efi"
            },
            "size": "512 MiB"
          },
          {
            "filesystem": {
              "type": "btrfs",
              "path": "/"
            }
          }
        ]
      }
    ]
  }
}
