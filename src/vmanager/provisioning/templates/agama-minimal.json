{
  "hostname": {
    "static": "{hostname}",
    "transient": "{hostname}"
  },
  "localization": {
    "language": "{language}",
    "keyboard": "{keyboard}",
    "timezone": "{timezone}"
  },
   "root": {
    "hashedPassword": true,
    "password": "{root_password}"
  },
  "user": {
    "hashedPassword": true,
    "fullName": "{username}",
    "userName": "{username}",
    "password": "{user_password}"
  },
  "product": {
    "id": "{OPENSUSE_PRODUCT_NAME}"
  },
  "software": {
    "patterns": [
      "minimal_base"
    ],
    "packages": [
      "qemu-guest-agent"
    ]
  },
  "bootloader": {
    "timeout": 5,
    "extraKernelParams": "quiet splash=silent showopts"
  },
  "network": {
    "connections": [
      {
        "id": "default",
        "method4": "auto"
      }
    ]
  },
  "storage": {
    "boot": {
      "configure": true,
      "device": "vda"
    },
    "drives": [
      {
        "partitions": [
          {
            "filesystem": {
              "type": "vfat",
              "path": "/boot/efi"
            },
            "size": "512 MiB"
          },
          {
            "filesystem": {
              "type": "swap",
              "path": "swap"
            },
            "size": "2 GiB"
          },
          {
            "filesystem": {
              "type": "btrfs",
              "path": "/"
            }
          }
        ]
      }
    ]
  }
}
