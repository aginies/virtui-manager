{
  "version": "1.0.0",
  "hostname": {
    "static": "{hostname}",
    "transient": "{hostname}"
  },
  "localization": {
    "language": "{language}",
    "keyboard": "{keyboard}",
    "timezone": "{timezone}"
  },
   "root": {
    "hashedPassword": null,
    "password": "{root_password}"
  },
  "user": {
    "hashedPassword": false,
    "autologin": false,
    "fullName": "{username}",
    "userName": "{username}",
    "password": "{user_password}"
  },
  "software": {
    "patterns": [
      "minimal_base"
    ],
    "packages": [
      "qemu-guest-agent"
    ]
  },
  "bootloader": {
    "stopOnBootMenu": false,
    "timeout": 5,
    "extraKernelParams": "quiet splash=silent showopts"
  },
  "storage": {
    "config": [
      {
        "id": "drive1",
        "device": "/dev/vda",
        "initialize": true,
        "platform": "efi"
      },
      {
        "id": "efi_partition",
        "type": "disk",
        "reuse": false,
        "device": "/dev/vda1",
        "mountpoint": "/boot/efi",
        "size_mib": 512,
        "fs_type": "vfat",
        "format": true
      },
      {
        "id": "root_partition",
        "type": "disk",
        "reuse": false,
        "device": "/dev/vda2",
        "mountpoint": "/",
        "size_mib": 0,
        "fs_type": "btrfs",
        "format": true
      }
    ],
    "mode": "fstab"
  },
  "ntp": {
    "enabled": true,
    "servers": [
      {
        "address": "2.suse.pool.ntp.org",
        "options": ["iburst"]
      }
    ]
  },
  "sysconfig": {
    "KEXEC_KDUMP_KERNEL": "no"
  },
  "services": {
    "enabled": ["sshd", "qemu-guest-agent"],
    "disabled": []
  }
}
